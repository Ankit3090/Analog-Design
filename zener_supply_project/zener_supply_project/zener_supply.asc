TEXT 1504 472 Left 2 !.param RLOAD=1k\n \n.step param RLOAD list 1k 470\n \n.tran 0 100m 0 100u\n \n\n \n.model D1N4007_EQ D(Is=7n Rs=0.05 N=1.9 Cjo=20p M=0.333 Vj=0.75 Bv=1000 Ibv=5u Tt=4u)\n \n.model D1N4733A_EQ D(Is=1n Rs=2 N=1.5 Cjo=250p Bv=5.1 Ibv=5m)\n \n\n \n.meas tran VOUT_AVG AVG V(VOUT) FROM=80m TO=100m\n \n.meas tran VOUT_MIN MIN V(VOUT) FROM=80m TO=100m\n \n.meas tran VOUT_MAX MAX V(VOUT) FROM=80m TO=100m\n \n.meas tran VOUT_RIPPLE_PP PARAM='VOUT_MAX-VOUT_MIN'\n \n\n \n.meas tran VRECT_PEAK MAX V(VRECT) FROM=80m TO=100m\n \n.meas tran VRECT_MIN MIN V(VRECT) FROM=80m TO=100m\n \n.meas tran VRECT_RIPPLE_PP PARAM='VRECT_PEAK-VRECT_MIN'\n \n\n \n.meas tran ILOAD_AVG AVG (V(VOUT)/{RLOAD}) FROM=80m TO=100m\n \n.meas tran IRSER_AVG AVG ((V(VRECT)-V(VOUT))/470) FROM=80m TO=100m\n \n.meas tran IZENER_REV_AVG AVG (-I(DZEN)) FROM=80m TO=100m\n \n.meas tran PRSER_AVG AVG (((V(VRECT)-V(VOUT))*(V(VRECT)-V(VOUT)))/470) FROM=80m TO=100m\n \n\n \n.meas tran T_RIPPLE TRIG V(VAC_IN,VAC_RET) VAL=0 RISE=1 TD=75m TARG V(VAC_IN,VAC_RET) VAL=0 FALL=1 TD=75m\n \n.meas tran F_VRECT_RIPPLE PARAM='1/T_RIPPLE'
