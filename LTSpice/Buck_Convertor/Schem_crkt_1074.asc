TEXT 2320 1192 Left 2 !.tran 2m startup\n \n.param RLOAD=5\n.step param RLOAD list 5 10 20\n \n.meas tran OUT_AVG AVG V(OUT) FROM=1.5m TO=2.0m\n.meas tran OUT_MAX MAX V(OUT) FROM=1.5m TO=2.0m\n.meas tran OUT_MIN MIN V(OUT) FROM=1.5m TO=2.0m\n.meas tran OUT_RIPPLE_PP PARAM='OUT_MAX-OUT_MIN'\n \n.meas tran ILOAD_AVG AVG (V(OUT)/{RLOAD}) FROM=1.5m TO=2.0m\n \n.meas tran T_SETTLE WHEN V(OUT)=4.8 RISE=1\n \n.meas tran TSW TRIG V(SW) VAL=10 RISE=1 TD=1.5m TARG V(SW) VAL=10 RISE=2 TD=1.5m\n.meas tran FSW_MEAS PARAM='1/TSW'\n \n.meas tran OUT_FILT_AVG AVG V(OUT_FILT) FROM=1.5m TO=2.0m\n.meas tran OUT_FILT_MAX MAX V(OUT_FILT) FROM=1.5m TO=2.0m\n.meas tran OUT_FILT_MIN MIN V(OUT_FILT) FROM=1.5m TO=2.0m\n.meas tran OUT_FILT_RIPPLE_PP PARAM='OUT_FILT_MAX-OUT_FILT_MIN'\n \n.meas tran VIN_SRC_AVG AVG V(VIN_SRC) FROM=1.5m TO=2.0m\n.meas tran IN_AVG AVG V(IN) FROM=1.5m TO=2.0m\n.meas tran IN_MAX MAX V(IN) FROM=1.5m TO=2.0m\n.meas tran IN_MIN MIN V(IN) FROM=1.5m TO=2.0m\n.meas tran VIN_DROOP_AVG PARAM='VIN_SRC_AVG-IN_AVG'\n.meas tran IN_RIPPLE_PP PARAM='IN_MAX-IN_MIN'
